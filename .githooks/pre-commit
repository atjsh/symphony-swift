#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Step 1: Run the symphony harness (tests + coverage gates)
echo "[symphony-build] pre-commit: running tests plus package, client, and server coverage gates" >&2
swift run --quiet --package-path "$repo_root" symphony-build harness

# Step 2: Format all Swift files in the repository and re-stage any changes
echo "[symphony-build] pre-commit: formatting Swift files" >&2
swift format --in-place --recursive --parallel "$repo_root"
changed_swift=$(git diff --name-only -- '*.swift')
if [ -n "$changed_swift" ]; then
    echo "$changed_swift" | xargs git add
fi
